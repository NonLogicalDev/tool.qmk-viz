    "keymapTemplate": "#include QMK_KEYBOARD_H\n\n/*\n * Generated by qmk-viz.\n * Project: {{ ctx.keyboardProject.name }}\n * Keyboard: {{ ctx.keyboard.name }}\n * Layout: {{ ctx.layout.name }}\n */\n\nenum layer_names {\n{% for layer in ctx.layout.layers %}\n    {{ layer.name }},\n{% endfor %}\n};\n\n#ifdef ST7565_ENABLE\n#    include \"lcd_setup.h\"\n#endif\n\nenum custom_keycodes {\n    NL_MS_L5 = SAFE_RANGE,\n    NL_MS_R5,\n    NL_MS_U5,\n    NL_MS_D5,\n{% for key in ctx.layout.extKeys %}\n{% if key.kind == \"macro\" %}\n    {{ key.name }},\n{% endif %}\n{% endfor %}\n    QMK_VIZ_SAFE_RANGE,\n};\n\n{% for key in ctx.layout.extKeys %}\n{% if key.kind != \"macro\" %}\n#define {{ key.name }} {{ key.value }}\n{% endif %}\n{% endfor %}\n\n// Macros\n{% macro K(layer, slot) %}{{ layer.keys[slot] or \"KC_TRNS\" }}{% endmacro %}\n\ntap_dance_action_t tap_dance_actions[] = {\n{% for name, dance in ctx.layout.dances %}\n    /* Basic tap/double-tap fallback; advanced hold dances need generated handlers. */\n    [{{ loop.index0 }}] = ACTION_TAP_DANCE_DOUBLE({{ dance.tap or \"KC_NO\" }}, {{ dance.doubleTap or dance.tap or \"KC_NO\" }}),\n{% else %}\n    [0] = ACTION_TAP_DANCE_DOUBLE(KC_NO, KC_NO),\n{% endfor %}\n};\n\nconst uint16_t PROGMEM keymaps[][MATRIX_ROWS][MATRIX_COLS] = {\n{% for layer in ctx.layout.layers %}\n    [{{ layer.name }}] = LAYOUT_ergodox(\n        // left hand\n        {{ K(layer, \"LT00\") }}, {{ K(layer, \"LT01\") }}, {{ K(layer, \"LT02\") }}, {{ K(layer, \"LT03\") }}, {{ K(layer, \"LT04\") }}, {{ K(layer, \"LT05\") }}, {{ K(layer, \"LT06\") }},\n        {{ K(layer, \"LT10\") }}, {{ K(layer, \"LT11\") }}, {{ K(layer, \"LT12\") }}, {{ K(layer, \"LT13\") }}, {{ K(layer, \"LT14\") }}, {{ K(layer, \"LT15\") }}, {{ K(layer, \"LT16\") }},\n        {{ K(layer, \"LT20\") }}, {{ K(layer, \"LT21\") }}, {{ K(layer, \"LT22\") }}, {{ K(layer, \"LT23\") }}, {{ K(layer, \"LT24\") }}, {{ K(layer, \"LT25\") }},\n        {{ K(layer, \"LT30\") }}, {{ K(layer, \"LT31\") }}, {{ K(layer, \"LT32\") }}, {{ K(layer, \"LT33\") }}, {{ K(layer, \"LT34\") }}, {{ K(layer, \"LT35\") }}, {{ K(layer, \"LT36\") }},\n        {{ K(layer, \"LT40\") }}, {{ K(layer, \"LT41\") }}, {{ K(layer, \"LT42\") }}, {{ K(layer, \"LT43\") }}, {{ K(layer, \"LT44\") }},\n        \n        // left thumb cluster\n        {{ K(layer, \"LC01\") }}, {{ K(layer, \"LC02\") }},\n        {{ K(layer, \"LC12\") }},\n        {{ K(layer, \"LC20\") }}, {{ K(layer, \"LC21\") }}, {{ K(layer, \"LC22\") }},\n\n        // right hand\n        {{ K(layer, \"RT06\") }}, {{ K(layer, \"RT05\") }}, {{ K(layer, \"RT04\") }}, {{ K(layer, \"RT03\") }}, {{ K(layer, \"RT02\") }}, {{ K(layer, \"RT01\") }}, {{ K(layer, \"RT00\") }},\n        {{ K(layer, \"RT16\") }}, {{ K(layer, \"RT15\") }}, {{ K(layer, \"RT14\") }}, {{ K(layer, \"RT13\") }}, {{ K(layer, \"RT12\") }}, {{ K(layer, \"RT11\") }}, {{ K(layer, \"RT10\") }},\n        {{ K(layer, \"RT25\") }}, {{ K(layer, \"RT24\") }}, {{ K(layer, \"RT23\") }}, {{ K(layer, \"RT22\") }}, {{ K(layer, \"RT21\") }}, {{ K(layer, \"RT20\") }},\n        {{ K(layer, \"RT36\") }}, {{ K(layer, \"RT35\") }}, {{ K(layer, \"RT34\") }}, {{ K(layer, \"RT33\") }}, {{ K(layer, \"RT32\") }}, {{ K(layer, \"RT31\") }}, {{ K(layer, \"RT30\") }},\n        {{ K(layer, \"RT44\") }}, {{ K(layer, \"RT43\") }}, {{ K(layer, \"RT42\") }}, {{ K(layer, \"RT41\") }}, {{ K(layer, \"RT40\") }},\n        \n        // right thumb cluster\n        {{ K(layer, \"RC02\") }}, {{ K(layer, \"RC01\") }},\n        {{ K(layer, \"RC12\") }},\n        {{ K(layer, \"RC22\") }}, {{ K(layer, \"RC21\") }}, {{ K(layer, \"RC20\") }}\n    ){% if not loop.last %},{% endif %}\n{% endfor %}\n};\n\nstatic void tap_code_times(uint16_t keycode, uint8_t times) {\n    for (uint8_t i = 0; i < times; ++i) {\n        tap_code16(keycode);\n    }\n}\n\nbool process_record_user(uint16_t keycode, keyrecord_t *record) {\n    if (!record->event.pressed) {\n        return true;\n    }\n\n    switch (keycode) {\n        case NL_MS_L5: tap_code_times(MS_LEFT, 5); return false;\n        case NL_MS_R5: tap_code_times(MS_RGHT, 5); return false;\n        case NL_MS_U5: tap_code_times(MS_UP, 5); return false;\n        case NL_MS_D5: tap_code_times(MS_DOWN, 5); return false;\n{% for key in ctx.layout.extKeys %}\n{% if key.kind == \"macro\" %}\n        case {{ key.name }}:\n            {{ key.value }};\n            return false;\n{% endif %}\n{% endfor %}\n    }\n\n    return true;\n}",
